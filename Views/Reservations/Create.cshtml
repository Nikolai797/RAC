@model RentACar.Web1.ViewModels.ReservationCreateViewModel

@{
    ViewData["Title"] = "Create Reservation";
}

<h1>Create Reservation</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="GetAvailableCars" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Check Availability" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@if (Model.AvailableCars != null && Model.AvailableCars.Any())
{
    <h3 class="mt-4">Available Cars</h3>
    <form asp-action="ConfirmReservation" method="post">
        <input type="hidden" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        <table class="table">
            <thead>
                <tr>
                    <th>Brand</th>
                    <th>Model</th>
                    <th>Year</th>
                    <th>Seats</th>
                    <th>Price/Day</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var car in Model.AvailableCars)
                {
                    <tr>
                        <td>@car.Brand</td>
                        <td>@car.Model</td>
                        <td>@car.Year</td>
                        <td>@car.Seats</td>
                        <td>@car.PricePerDay.ToString("C")</td>
                        <td>
                            <button type="submit" name="carId" value="@car.Id" class="btn btn-success btn-sm">Book</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </form>
}
else if (Model.AvailableCars != null)
{
    <div class="alert alert-warning mt-4">No cars available for the selected dates.</div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}