@model IEnumerable<RentACar.Data.Models.Car>

@{
    ViewData["Title"] = "Manage Cars";
}

<h1>Manage Cars</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Car</a>
</p>

<table class="table">
    <thead>
        32<th>Brand</th>
            <th>Model</th>
            <th>Year</th>
            <th>Seats</th>
            <th>Price/Day</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Brand</td>
                <td>@item.Model</td>
                <td>@item.Year</td>
                <td>@item.Seats</td>
                <td>@item.PricePerDay.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>